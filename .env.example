# Database
POSTGRES_USER=qstudio
POSTGRES_PASSWORD=qstudio_dev_password_change_in_production
POSTGRES_DB=qstudio

# Redis
REDIS_PASSWORD=qstudio_dev_redis_change_in_production

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API URLs
API_URL=http://api:8000
FRONTEND_URL=http://web:3000

# AI API Keys
OPENAI_API_KEY=your-openai-api-key
REPLICATE_API_TOKEN=your-replicate-api-token

# Nginx
SSL_EMAIL=admin@qstudio.com
